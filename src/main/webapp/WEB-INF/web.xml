<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         version="6.0">

    <servlet>
        <servlet-name>ProductoServlet</servlet-name>
        <servlet-class>controller.ProductoServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ProductoServlet</servlet-name>
        <url-pattern>/productos</url-pattern>
    </servlet-mapping>

</web-app>
